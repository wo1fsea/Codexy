{
  "name": "codexy",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "node scripts/next-dev.mjs --hostname 0.0.0.0 --port 3001",
    "build": "node scripts/next-build.mjs",
    "start": "node scripts/next-start.mjs",
    "restart:3001": "node scripts/restart-3001.mjs",
    "typecheck": "tsc --noEmit",
    "test:first-run": "node --test tests/first-run.test.mjs",
    "test:e2e": "playwright test",
    "verify:first-run": "npm run test:first-run",
    "verify": "node scripts/verify.mjs",
    "verify:e2e": "node scripts/verify.mjs --e2e"
  },
  "dependencies": {
    "clsx": "^2.1.1",
    "next": "^16.0.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-markdown": "^10.1.0",
    "remark-breaks": "^4.0.0",
    "remark-gfm": "^4.0.1",
    "ws": "^8.18.3",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/node": "^24.6.0",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@types/ws": "^8.18.1",
    "typescript": "^5.9.3"
  }
}
